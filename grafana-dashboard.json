{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Acquire Rate (ops/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(distributed_lock_acquire_success_total[5m])",
          "legendFormat": "success"
        },
        {
          "expr": "rate(distributed_lock_acquire_failed_total[5m])",
          "legendFormat": "failed"
        }
      ]
    },
    {
      "title": "Release & Renew Rate (ops/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(distributed_lock_release_success_total[5m])",
          "legendFormat": "release success"
        },
        {
          "expr": "rate(distributed_lock_release_failed_total[5m])",
          "legendFormat": "release failed"
        },
        {
          "expr": "rate(distributed_lock_renew_success_total[5m])",
          "legendFormat": "renew success"
        },
        {
          "expr": "rate(distributed_lock_renew_failed_total[5m])",
          "legendFormat": "renew failed"
        }
      ]
    },
    {
      "title": "Acquire Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(distributed_lock_acquire_duration_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(distributed_lock_acquire_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(distributed_lock_acquire_duration_ms_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Backend Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "increase(distributed_lock_backend_errors_total[5m])"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Acquire Success Ratio",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "rate(distributed_lock_acquire_success_total[5m]) / (rate(distributed_lock_acquire_success_total[5m]) + rate(distributed_lock_acquire_failed_total[5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "title": "Contention Wait Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(distributed_lock_contention_wait_ms_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(distributed_lock_contention_wait_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(distributed_lock_contention_wait_ms_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Fencing Tokens Issued",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "increase(distributed_lock_fencing_tokens_issued_total[5m])",
          "legendFormat": "issued"
        }
      ]
    },
    {
      "title": "Degraded Modes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(distributed_lock_acquire_contention_total[5m])",
          "legendFormat": "contention"
        },
        {
          "expr": "rate(distributed_lock_backend_unavailable_total[5m])",
          "legendFormat": "backend unavailable"
        },
        {
          "expr": "rate(distributed_lock_fail_open_acquire_total[5m])",
          "legendFormat": "fail-open synthetic"
        },
        {
          "expr": "rate(distributed_lock_lost_total[5m])",
          "legendFormat": "lock lost"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["distributed-lock", "redis"],
